<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>報價單產生器</title>

<!-- 字型：介面用 Noto Sans TC，文件標題用 Noto Serif TC（增加正式文件感） -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&family=Noto+Serif+TC:wght@600;700&display=swap" rel="stylesheet">

<style>
/* ============================================================
   設計 Token（顏色 / 字型 / 尺寸）
   走「會計帳本」的專業感：沉穩墨綠為唯一重點色，
   金額欄位使用等寬對齊數字（tabular-nums）。
   ============================================================ */
:root{
  /* ECOCO 宜可可循環經濟 品牌色：藍為主結構、橘為行動重點 */
  --paper:       #FBFAFA;   /* 頁面背景 */
  --card:        #FFFFFF;   /* 卡片底色 */
  --ink:         #14213A;   /* 主文字（深藍墨，呼應品牌藍） */
  --muted:       #6E7580;   /* 次要文字 */
  --accent:      #1319A2;   /* 品牌藍：結構 / 焦點 / 表頭 */
  --accent-soft: #ECEDFA;   /* 淺藍底 */
  --accent2:     #FD580C;   /* 品牌橘：主要行動按鈕 / 總額強調 */
  --accent2-dark:#DB4A08;   /* 橘 hover */
  --accent2-soft:#FFF1E9;   /* 淺橘底 */
  --line:        #E4E7E5;   /* 分隔線 / 邊框 */
  --danger:      #C0392B;   /* 刪除 / 警示（與品牌橘區隔） */
  --shadow:      0 1px 2px rgba(20,33,58,.04), 0 8px 24px rgba(20,33,58,.07);
  --radius:      10px;
}

*{ box-sizing:border-box; }
html,body{ margin:0; padding:0; }
body{
  font-family:"Noto Sans TC", system-ui, -apple-system, "PingFang TC", "Microsoft JhengHei", sans-serif;
  background:var(--paper);
  color:var(--ink);
  line-height:1.6;
  -webkit-font-smoothing:antialiased;
}

/* 數字統一等寬對齊，金額才會像帳本一樣整齊 */
.num{ font-variant-numeric: tabular-nums; }

/* ---------- 頁首 ---------- */
.topbar{
  display:flex; align-items:center; justify-content:space-between;
  gap:16px; flex-wrap:wrap;
  padding:18px 24px;
  border-bottom:1px solid var(--line);
  background:var(--card);
}
.topbar .brand{ display:flex; align-items:center; gap:14px; }
.topbar .brand .logo{ height:30px; width:auto; display:block; }
.topbar .brand .divider{ width:1px; height:24px; background:var(--line); }
.topbar h1{
  font-family:"Noto Serif TC", serif;
  font-size:20px; font-weight:700; margin:0; letter-spacing:2px;
}
.topbar .brand small{ color:var(--muted); font-size:13px; }
.topbar .actions{ display:flex; gap:10px; flex-wrap:wrap; }

/* ---------- 版面：左編輯 / 右預覽 ---------- */
.layout{
  display:grid;
  grid-template-columns: minmax(0,1fr) minmax(0,1fr);
  gap:24px;
  max-width:1280px;
  margin:24px auto;
  padding:0 24px;
}
@media (max-width: 960px){
  .layout{ grid-template-columns:1fr; }
}

/* ---------- 區塊卡片 ---------- */
.card{
  background:var(--card);
  border:1px solid var(--line);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
  padding:20px;
  margin-bottom:20px;
}
.card > h2{
  font-size:14px; font-weight:700; margin:0 0 16px;
  color:var(--accent);
  letter-spacing:.5px;
  display:flex; align-items:center; gap:8px;
}
.card > h2::before{
  content:""; width:3px; height:14px; background:var(--accent); border-radius:2px;
}

/* ---------- 表單元件 ---------- */
label{ display:block; font-size:12.5px; color:var(--muted); margin-bottom:5px; }
.req::after{ content:" *"; color:var(--danger); }

input, select, textarea{
  width:100%;
  font-family:inherit; font-size:14px; color:var(--ink);
  padding:9px 11px;
  border:1px solid var(--line);
  border-radius:8px;
  background:#fff;
  transition:border-color .15s, box-shadow .15s;
}
input:focus, select:focus, textarea:focus{
  outline:none;
  border-color:var(--accent);
  box-shadow:0 0 0 3px var(--accent-soft);
}
textarea{ resize:vertical; min-height:64px; }

.grid-2{ display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.grid-3{ display:grid; grid-template-columns:1fr 1fr 1fr; gap:14px; }
.field{ margin-bottom:14px; }
.field:last-child{ margin-bottom:0; }
@media (max-width:520px){
  .grid-2, .grid-3{ grid-template-columns:1fr; }
}

/* ---------- 按鈕 ---------- */
button{
  font-family:inherit; font-size:14px; font-weight:500;
  cursor:pointer; border-radius:8px; border:1px solid transparent;
  padding:9px 16px; transition:all .15s;
}
.btn-primary{ background:var(--accent2); color:#fff; }
.btn-primary:hover{ background:var(--accent2-dark); }
.btn-ghost{ background:#fff; color:var(--ink); border-color:var(--line); }
.btn-ghost:hover{ border-color:var(--accent); color:var(--accent); }
.btn-sm{ padding:6px 12px; font-size:13px; }

/* ---------- 產品項目列 ---------- */
.items-head, .item-row{
  display:grid;
  grid-template-columns: 2.4fr 0.9fr 1.2fr 1.4fr 36px;
  gap:10px; align-items:center;
}
.items-head{
  font-size:12px; color:var(--muted); padding:0 4px 8px;
  border-bottom:1px solid var(--line); margin-bottom:12px;
}
.items-head span:nth-child(n+2){ text-align:right; }
.item-row{ margin-bottom:10px; }
.item-row .subtotal{
  text-align:right; font-weight:500; padding-right:4px;
  color:var(--ink);
}
.item-del{
  background:none; border:none; color:var(--muted);
  font-size:18px; line-height:1; padding:4px; border-radius:6px;
}
.item-del:hover{ color:var(--danger); background:#faeceb; }
@media (max-width:520px){
  /* 手機：項目改為卡片式堆疊，避免擠成一團 */
  .items-head{ display:none; }
  .item-row{
    grid-template-columns:1fr 1fr; gap:8px;
    border:1px solid var(--line); border-radius:8px; padding:12px; position:relative;
  }
  .item-row .i-name{ grid-column:1 / -1; }
  .item-row .subtotal{ grid-column:1 / -1; text-align:left; padding:6px 0 0; border-top:1px dashed var(--line); }
  .item-del{ position:absolute; top:8px; right:8px; }
}

/* ---------- 設定列（稅率 / 幣別 / 折扣） ---------- */
.seg{ display:inline-flex; border:1px solid var(--line); border-radius:8px; overflow:hidden; }
.seg button{
  border:none; border-radius:0; background:#fff; color:var(--muted);
  padding:8px 14px; font-size:13px;
}
.seg button.active{ background:var(--accent); color:#fff; }

/* ============================================================
   預覽區：一張真實的報價單文件（可直接列印 / 存 PDF）
   ============================================================ */
.preview-wrap{ position:sticky; top:16px; }
.preview-document{
  background:#fff;
  border:1px solid var(--line);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
  padding:40px 44px;
  color:var(--ink);
}
.doc-header{
  display:flex; justify-content:space-between; align-items:flex-start;
  gap:24px; padding-bottom:20px; margin-bottom:24px;
  /* 藍→橘雙色底線，呼應 ECOCO Logo */
  border-bottom:3px solid transparent;
  border-image:linear-gradient(90deg, var(--accent) 0 55%, var(--accent2) 55% 100%) 1;
}
.doc-header .supplier{ min-width:0; }
.doc-header .doc-logo{ height:44px; width:auto; display:block; margin-bottom:12px; }
.doc-header .company .name{ font-weight:700; font-size:16px; }
.doc-header .company .meta{ color:var(--muted); font-size:12.5px; margin-top:3px; white-space:pre-wrap; }
.doc-title-wrap{ text-align:right; flex-shrink:0; }
.doc-title{
  font-family:"Noto Serif TC", serif; font-size:34px; font-weight:700;
  letter-spacing:10px; margin:0; line-height:1; color:var(--ink);
}
.doc-title-wrap .sub{
  font-size:12px; letter-spacing:4px; color:var(--accent2);
  font-weight:700; margin-top:8px;
}

.doc-meta{ display:flex; justify-content:space-between; gap:24px; margin-bottom:24px; flex-wrap:wrap; }
.doc-meta .block{ font-size:13px; }
.doc-meta .block .k{ color:var(--muted); font-size:11.5px; letter-spacing:.5px; }
.doc-meta .block .v{ font-weight:500; }
.doc-meta .block .v.big{ font-size:15px; }

/* 預覽表格 */
table.doc-table{ width:100%; border-collapse:collapse; margin-bottom:20px; font-size:13.5px; }
.doc-table thead th{
  background:var(--accent-soft); color:var(--accent);
  font-weight:700; font-size:12px; letter-spacing:.5px;
  padding:10px 12px; text-align:left;
}
.doc-table thead th.r{ text-align:right; }
.doc-table tbody td{ padding:11px 12px; border-bottom:1px solid var(--line); vertical-align:top; }
.doc-table tbody td.r{ text-align:right; }
.doc-table tbody tr:last-child td{ border-bottom:1px solid var(--ink); }
.doc-table .empty td{ color:var(--muted); text-align:center; padding:24px; font-size:13px; }

/* 合計區 */
.totals{ display:flex; justify-content:flex-end; margin-bottom:24px; }
.totals table{ width:min(320px, 100%); font-size:14px; }
.totals td{ padding:7px 0; }
.totals td.k{ color:var(--muted); }
.totals td.v{ text-align:right; font-weight:500; }
.totals tr.discount td{ color:var(--danger); }
.totals tr.grand td{
  border-top:2px solid var(--ink); padding-top:12px;
  font-size:19px; font-weight:700; color:var(--accent2);
}
.doc-note{ font-size:13px; color:var(--muted); border-top:1px dashed var(--line); padding-top:16px; white-space:pre-wrap; }
.doc-note .k{ font-weight:700; color:var(--ink); display:block; margin-bottom:4px; }

/* ---------- 歷史紀錄 ---------- */
.history-list{ display:flex; flex-direction:column; gap:8px; }
.history-item{
  display:flex; align-items:center; justify-content:space-between; gap:12px;
  padding:12px 14px; border:1px solid var(--line); border-radius:8px; background:#fff;
}
.history-item .info{ min-width:0; }
.history-item .info .t{ font-weight:500; font-size:14px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.history-item .info .s{ font-size:12px; color:var(--muted); }
.history-item .ops{ display:flex; gap:6px; flex-shrink:0; }
.empty-hint{ color:var(--muted); font-size:13px; text-align:center; padding:16px; }

/* ---------- 列印：只印預覽文件 ---------- */
@media print{
  body{ background:#fff; }
  .topbar, .editor-col, .preview-wrap > .no-print, .history-card{ display:none !important; }
  .layout{ display:block; margin:0; padding:0; max-width:none; }
  .preview-wrap{ position:static; }
  .preview-document{ border:none; box-shadow:none; border-radius:0; padding:0; }
  @page{ margin:16mm; }
}
</style>
</head>
<body>

<!-- ======================= 頁首 ======================= -->
<header class="topbar">
  <div class="brand">
    <img class="logo" src="data:image/png;base64," alt="ECOCO 宜可可循環經濟">
    <span class="divider"></span>
    <h1>報 價 單</h1>
    <small>報價單產生器 · 即時預覽</small>
  </div>
  <div class="actions">
    <button class="btn-ghost" id="btnSave">儲存此報價</button>
    <button class="btn-ghost" id="btnReset">清除重填</button>
    <button class="btn-primary" id="btnPrint">列印 / 存成 PDF</button>
  </div>
</header>

<div class="layout">

  <!-- ======================= 左：編輯區 ======================= -->
  <section class="editor-col">

    <!-- 供應商（抬頭）資訊 -->
    <div class="card">
      <h2>供應商資訊</h2>
      <div class="field">
        <label for="f-company">公司 / 抬頭名稱</label>
        <input id="f-company" type="text" placeholder="例：晴光實業有限公司" data-path="meta.company">
      </div>
      <div class="grid-2">
        <div class="field">
          <label for="f-quoteNo">報價單號</label>
          <input id="f-quoteNo" type="text" data-path="meta.quoteNo">
        </div>
        <div class="field">
          <label for="f-supplierContact">供應商聯絡資訊</label>
          <input id="f-supplierContact" type="text" placeholder="電話 / Email / 統編" data-path="meta.supplierContact">
        </div>
      </div>
    </div>

    <!-- 客戶資料 -->
    <div class="card">
      <h2>客戶資料</h2>
      <div class="field">
        <label for="f-custName" class="req">客戶名稱</label>
        <input id="f-custName" type="text" placeholder="例：王小明 / ○○科技股份有限公司" data-path="customer.name">
      </div>
      <div class="grid-3">
        <div class="field">
          <label for="f-custEmail">Email</label>
          <input id="f-custEmail" type="email" placeholder="name@example.com" data-path="customer.email">
        </div>
        <div class="field">
          <label for="f-custPhone">電話</label>
          <input id="f-custPhone" type="tel" placeholder="02-1234-5678" data-path="customer.phone">
        </div>
        <div class="field">
          <label for="f-date">報價日期</label>
          <input id="f-date" type="date" data-path="meta.date">
        </div>
      </div>
    </div>

    <!-- 產品項目 -->
    <div class="card">
      <h2>產品項目</h2>
      <div class="items-head">
        <span>品名</span><span>數量</span><span>單價</span><span>小計</span><span></span>
      </div>
      <div id="itemsBox"><!-- 動態產生項目列 --></div>
      <button class="btn-ghost btn-sm" id="btnAddItem" style="margin-top:6px;">＋ 新增項目</button>
    </div>

    <!-- 計價設定：幣別 / 稅率 / 折扣 -->
    <div class="card">
      <h2>計價設定</h2>
      <div class="grid-2" style="margin-bottom:16px;">
        <div class="field" style="margin-bottom:0;">
          <label>幣別</label>
          <div class="seg" id="segCurrency">
            <button data-cur="TWD" class="active">TWD（NT$）</button>
            <button data-cur="USD">USD（US$）</button>
          </div>
        </div>
        <div class="field" style="margin-bottom:0;">
          <label>稅率</label>
          <div class="seg" id="segTax">
            <button data-tax="0.05" class="active">5%</button>
            <button data-tax="0.08">8%</button>
          </div>
        </div>
      </div>

      <label>折扣（選填）</label>
      <div class="grid-2">
        <div class="field" style="margin-bottom:0;">
          <select id="f-discountType" data-path="meta.discountType">
            <option value="none">不折扣</option>
            <option value="percent">折扣百分比（%）</option>
            <option value="amount">折扣金額</option>
          </select>
        </div>
        <div class="field" style="margin-bottom:0;">
          <input id="f-discountValue" type="number" min="0" step="any" placeholder="輸入折扣數值" data-path="meta.discountValue" disabled>
        </div>
      </div>
    </div>

    <!-- 備註 -->
    <div class="card">
      <h2>備註 / 付款條件</h2>
      <textarea id="f-note" placeholder="例：本報價有效期 14 天；款項請於收到貨品後 7 日內匯款。" data-path="meta.note"></textarea>
    </div>

    <!-- 歷史報價（localStorage） -->
    <div class="card history-card">
      <h2>歷史報價</h2>
      <div class="history-list" id="historyBox"></div>
    </div>

  </section>

  <!-- ======================= 右：即時預覽 ======================= -->
  <aside class="preview-wrap">
    <div class="preview-document" id="preview"><!-- 由 renderPreview() 產生 --></div>
  </aside>

</div>

<script>
"use strict";

/* ECOCO 品牌 Logo（base64 內嵌，維持單一檔案；輸出報價單時會顯示） */
const LOGO_SRC = "data:image/png;base64,";

/* ============================================================
   1. 狀態（單一資料來源）
   所有畫面都由這個 state 物件推導出來。
   ============================================================ */
const state = {
  meta: {
    company: "宜可可循環經濟",   // 預設抬頭（可修改）
    quoteNo: genQuoteNo(),      // 自動產生單號，可修改
    supplierContact: "",
    date: todayStr(),           // 預設今天
    currency: "TWD",            // TWD | USD
    taxRate: 0.05,              // 0.05 | 0.08
    discountType: "none",       // none | percent | amount
    discountValue: 0,
    note: ""
  },
  customer: { name: "", email: "", phone: "" },
  items: []                      // { id, name, qty, price }
};

const STORAGE_KEY = "quote_generator_history_v1";

/* ---------- 小工具函式 ---------- */
// 今天日期 YYYY-MM-DD
function todayStr(){
  const d = new Date();
  const p = n => String(n).padStart(2, "0");
  return `${d.getFullYear()}-${p(d.getMonth()+1)}-${p(d.getDate())}`;
}
// 產生報價單號：Q + 日期 + 3 碼流水
function genQuoteNo(){
  const d = new Date();
  const p = n => String(n).padStart(2, "0");
  const rnd = String(Math.floor(Math.random()*1000)).padStart(3, "0");
  return `Q${d.getFullYear()}${p(d.getMonth()+1)}${p(d.getDate())}-${rnd}`;
}
// 產生項目唯一 id
function uid(){ return "it_" + Math.random().toString(36).slice(2, 9); }

// 金額格式化（TWD 不含小數、USD 兩位小數）
function fmtMoney(n, currency = state.meta.currency){
  const cur = currency || state.meta.currency;
  const symbol = cur === "USD" ? "US$" : "NT$";
  const digits = cur === "USD" ? 2 : 0;
  const num = Number(n) || 0;
  return symbol + num.toLocaleString("en-US", {
    minimumFractionDigits: digits,
    maximumFractionDigits: digits
  });
}
// HTML 轉義，避免使用者輸入破壞版面
function esc(s){
  return String(s ?? "").replace(/[&<>"']/g, c => (
    {"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"}[c]
  ));
}

/* ============================================================
   2. 核心計算：小計 / 未稅 / 折扣 / 稅金 / 含稅總額
   ============================================================ */
function compute(){
  // 每項小計 = 數量 × 單價
  const items = state.items.map(it => ({
    ...it,
    subtotal: (Number(it.qty) || 0) * (Number(it.price) || 0)
  }));
  // 未稅總額（折扣前）
  const preTax = items.reduce((sum, it) => sum + it.subtotal, 0);

  // 折扣：百分比或固定金額，且不超過未稅總額
  let discount = 0;
  const dv = Number(state.meta.discountValue) || 0;
  if (state.meta.discountType === "percent") discount = preTax * (dv / 100);
  else if (state.meta.discountType === "amount") discount = dv;
  discount = Math.max(0, Math.min(discount, preTax));

  const taxable = preTax - discount;      // 折扣後未稅金額（課稅基礎）
  const tax = taxable * state.meta.taxRate; // 稅金
  const total = taxable + tax;            // 含稅總額

  return { items, preTax, discount, taxable, tax, total };
}

/* ============================================================
   3. 產品項目列的建立與繫結
   直接操作 DOM 建立每一列，輸入時只更新 state + 預覽，
   不重繪整個表單，避免輸入時游標跳掉。
   ============================================================ */
function buildItemRow(item){
  const row = document.createElement("div");
  row.className = "item-row";
  row.dataset.id = item.id;
  row.innerHTML = `
    <input class="i-name" type="text" placeholder="產品 / 服務名稱" value="${esc(item.name)}">
    <input class="i-qty num" type="number" min="0" step="any" placeholder="0" value="${item.qty ?? ""}" style="text-align:right;">
    <input class="i-price num" type="number" min="0" step="any" placeholder="0" value="${item.price ?? ""}" style="text-align:right;">
    <div class="subtotal num">—</div>
    <button class="item-del" title="刪除此項目">×</button>
  `;

  const $name  = row.querySelector(".i-name");
  const $qty   = row.querySelector(".i-qty");
  const $price = row.querySelector(".i-price");
  const $del   = row.querySelector(".item-del");

  // 任一欄位變動 → 更新 state 中對應項目 → 重算並更新預覽
  function sync(){
    const target = state.items.find(x => x.id === item.id);
    if(!target) return;
    target.name  = $name.value;
    target.qty   = $qty.value;
    target.price = $price.value;
    render();
  }
  $name.addEventListener("input", sync);
  $qty.addEventListener("input", sync);
  $price.addEventListener("input", sync);

  // 刪除項目
  $del.addEventListener("click", () => {
    state.items = state.items.filter(x => x.id !== item.id);
    row.remove();
    render();
  });

  return row;
}

// 新增一個空項目
function addItem(prefill){
  const item = Object.assign({ id: uid(), name:"", qty:"", price:"" }, prefill || {});
  state.items.push(item);
  document.getElementById("itemsBox").appendChild(buildItemRow(item));
  render();
}

// 依 state.items 重建整個項目區（載入歷史 / 清除時使用）
function rebuildItems(){
  const box = document.getElementById("itemsBox");
  box.innerHTML = "";
  state.items.forEach(item => box.appendChild(buildItemRow(item)));
}

/* ============================================================
   4. 渲染：更新每列小計 + 右側預覽文件
   ============================================================ */
function render(){
  const data = compute();

  // 4-1 更新每一列的小計數字
  document.querySelectorAll(".item-row").forEach(row => {
    const id = row.dataset.id;
    const found = data.items.find(x => x.id === id);
    row.querySelector(".subtotal").textContent = found ? fmtMoney(found.subtotal) : "—";
  });

  // 4-2 更新右側預覽
  renderPreview(data);
}

function renderPreview(data){
  const m = state.meta, c = state.customer;

  // 項目列（無資料時顯示提示）
  const rowsHtml = data.items.length
    ? data.items.map((it, i) => `
        <tr>
          <td>${i+1}</td>
          <td>${esc(it.name) || '<span style="color:var(--muted)">（未命名）</span>'}</td>
          <td class="r num">${(Number(it.qty)||0).toLocaleString("en-US")}</td>
          <td class="r num">${fmtMoney(it.price)}</td>
          <td class="r num">${fmtMoney(it.subtotal)}</td>
        </tr>`).join("")
    : `<tr class="empty"><td colspan="5">尚未新增任何項目</td></tr>`;

  // 折扣列（有折扣才顯示）
  const discountRow = data.discount > 0 ? `
    <tr class="discount">
      <td class="k">折扣${m.discountType === "percent" ? `（${Number(m.discountValue)||0}%）` : ""}</td>
      <td class="v num">− ${fmtMoney(data.discount)}</td>
    </tr>` : "";

  document.getElementById("preview").innerHTML = `
    <div class="doc-header">
      <div class="supplier company">
        <img class="doc-logo" src="${LOGO_SRC}" alt="ECOCO 宜可可循環經濟">
        <div class="name">${esc(m.company) || "（供應商名稱）"}</div>
        ${m.supplierContact ? `<div class="meta">${esc(m.supplierContact)}</div>` : ""}
      </div>
      <div class="doc-title-wrap">
        <h2 class="doc-title">報價單</h2>
        <div class="sub">QUOTATION</div>
      </div>
    </div>

    <div class="doc-meta">
      <div class="block">
        <div class="k">客戶</div>
        <div class="v big">${esc(c.name) || "（客戶名稱）"}</div>
        ${c.email ? `<div class="v" style="color:var(--muted)">${esc(c.email)}</div>` : ""}
        ${c.phone ? `<div class="v" style="color:var(--muted)">${esc(c.phone)}</div>` : ""}
      </div>
      <div class="block" style="text-align:right;">
        <div style="margin-bottom:8px;"><span class="k">報價單號　</span><span class="v">${esc(m.quoteNo)}</span></div>
        <div><span class="k">報價日期　</span><span class="v">${esc(m.date)}</span></div>
      </div>
    </div>

    <table class="doc-table">
      <thead>
        <tr>
          <th style="width:36px;">#</th>
          <th>品名</th>
          <th class="r" style="width:70px;">數量</th>
          <th class="r" style="width:110px;">單價</th>
          <th class="r" style="width:120px;">小計</th>
        </tr>
      </thead>
      <tbody>${rowsHtml}</tbody>
    </table>

    <div class="totals">
      <table>
        <tr><td class="k">未稅小計</td><td class="v num">${fmtMoney(data.preTax)}</td></tr>
        ${discountRow}
        <tr><td class="k">稅金（${(m.taxRate*100).toFixed(0)}%）</td><td class="v num">${fmtMoney(data.tax)}</td></tr>
        <tr class="grand"><td class="k">含稅總額</td><td class="v num">${fmtMoney(data.total)}</td></tr>
      </table>
    </div>

    ${m.note ? `<div class="doc-note"><span class="k">備註</span>${esc(m.note)}</div>` : ""}
  `;
}

/* ============================================================
   5. 表單雙向繫結（data-path）
   有 data-path 的欄位會自動寫回 state 對應路徑。
   ============================================================ */
function setByPath(obj, path, value){
  const keys = path.split(".");
  let o = obj;
  for(let i = 0; i < keys.length - 1; i++) o = o[keys[i]];
  o[keys[keys.length - 1]] = value;
}
function getByPath(obj, path){
  return path.split(".").reduce((o, k) => (o ? o[k] : undefined), obj);
}

function bindInputs(){
  document.querySelectorAll("[data-path]").forEach(el => {
    el.addEventListener("input", () => {
      setByPath(state, el.dataset.path, el.value);

      // 折扣類型改變時，啟用／停用折扣數值輸入框
      if(el.id === "f-discountType"){
        const dv = document.getElementById("f-discountValue");
        dv.disabled = (el.value === "none");
        if(el.value === "none") dv.value = "";
      }
      render();
    });
  });
}

// 把 state 的值回填到表單（載入歷史 / 初始化時使用）
function fillForm(){
  document.querySelectorAll("[data-path]").forEach(el => {
    const v = getByPath(state, el.dataset.path);
    el.value = (v ?? "");
  });
  // 幣別 / 稅率的分段按鈕
  updateSeg("segCurrency", "cur", state.meta.currency);
  updateSeg("segTax", "tax", String(state.meta.taxRate));
  // 折扣輸入框啟用狀態
  document.getElementById("f-discountValue").disabled = (state.meta.discountType === "none");
}

/* ---------- 分段按鈕（幣別 / 稅率） ---------- */
function updateSeg(segId, attr, value){
  document.querySelectorAll(`#${segId} button`).forEach(b => {
    b.classList.toggle("active", b.dataset[attr] === value);
  });
}
function bindSegments(){
  document.querySelectorAll("#segCurrency button").forEach(b => {
    b.addEventListener("click", () => {
      state.meta.currency = b.dataset.cur;
      updateSeg("segCurrency", "cur", b.dataset.cur);
      render();
    });
  });
  document.querySelectorAll("#segTax button").forEach(b => {
    b.addEventListener("click", () => {
      state.meta.taxRate = Number(b.dataset.tax);
      updateSeg("segTax", "tax", b.dataset.tax);
      render();
    });
  });
}

/* ============================================================
   6. localStorage：歷史報價 儲存 / 載入 / 刪除
   以 try/catch 包裹，若環境不支援（如某些預覽沙箱）也不會壞掉。
   ============================================================ */
function loadHistory(){
  try{
    return JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];
  }catch(e){
    return [];
  }
}
function persistHistory(list){
  try{
    localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
    return true;
  }catch(e){
    return false;
  }
}

function saveCurrent(){
  if(!state.customer.name.trim()){
    alert("請先填寫「客戶名稱」再儲存。");
    document.getElementById("f-custName").focus();
    return;
  }
  const data = compute();
  const record = {
    id: "rec_" + Date.now(),
    savedAt: new Date().toLocaleString("zh-TW", { hour12:false }),
    snapshot: JSON.parse(JSON.stringify(state)), // 完整快照
    summary: {
      customer: state.customer.name,
      quoteNo: state.meta.quoteNo,
      total: data.total,
      currency: state.meta.currency
    }
  };
  const list = loadHistory();
  list.unshift(record);
  const ok = persistHistory(list);
  if(!ok){
    alert("此環境無法使用瀏覽器儲存空間。\n部署到網站（如 GitHub Pages）後即可正常儲存歷史報價。");
    return;
  }
  renderHistory();
}

function loadRecord(id){
  const rec = loadHistory().find(r => r.id === id);
  if(!rec) return;
  // 還原快照到 state（含 items 帶新 id 以利刪除）
  Object.assign(state.meta, rec.snapshot.meta);
  Object.assign(state.customer, rec.snapshot.customer);
  state.items = (rec.snapshot.items || []).map(it => ({ ...it, id: uid() }));
  fillForm();
  rebuildItems();
  render();
  window.scrollTo({ top:0, behavior:"smooth" });
}

function deleteRecord(id){
  if(!confirm("確定要刪除這筆歷史報價？")) return;
  persistHistory(loadHistory().filter(r => r.id !== id));
  renderHistory();
}

function renderHistory(){
  const box = document.getElementById("historyBox");
  const list = loadHistory();
  if(!list.length){
    box.innerHTML = `<div class="empty-hint">尚無儲存的報價。填寫後點「儲存此報價」即可留存。</div>`;
    return;
  }
  box.innerHTML = list.map(r => `
    <div class="history-item">
      <div class="info">
        <div class="t">${esc(r.summary.customer)}　·　${fmtMoney(r.summary.total, r.summary.currency)}</div>
        <div class="s">${esc(r.summary.quoteNo)}　·　${esc(r.savedAt)}</div>
      </div>
      <div class="ops">
        <button class="btn-ghost btn-sm" data-load="${r.id}">載入</button>
        <button class="btn-ghost btn-sm" data-del="${r.id}" style="color:var(--danger);">刪除</button>
      </div>
    </div>
  `).join("");

  box.querySelectorAll("[data-load]").forEach(b =>
    b.addEventListener("click", () => loadRecord(b.dataset.load)));
  box.querySelectorAll("[data-del]").forEach(b =>
    b.addEventListener("click", () => deleteRecord(b.dataset.del)));
}

/* ============================================================
   7. 頂部按鈕：列印 / 清除
   ============================================================ */
function resetAll(){
  if(!confirm("確定要清除目前所有內容，重新填寫？")) return;
  state.meta = {
    company:"宜可可循環經濟", quoteNo:genQuoteNo(), supplierContact:"", date:todayStr(),
    currency:"TWD", taxRate:0.05, discountType:"none", discountValue:0, note:""
  };
  state.customer = { name:"", email:"", phone:"" };
  state.items = [];
  fillForm();
  rebuildItems();
  addItem();  // 保留一列空白項目
  render();
}

/* ============================================================
   8. 初始化
   ============================================================ */
function init(){
  bindInputs();
  bindSegments();
  fillForm();

  document.getElementById("btnAddItem").addEventListener("click", () => addItem());
  document.getElementById("btnSave").addEventListener("click", saveCurrent);
  document.getElementById("btnReset").addEventListener("click", resetAll);
  document.getElementById("btnPrint").addEventListener("click", () => window.print());

  addItem();        // 預設先給一列空白項目
  renderHistory();
  render();
}

document.addEventListener("DOMContentLoaded", init);
</script>
